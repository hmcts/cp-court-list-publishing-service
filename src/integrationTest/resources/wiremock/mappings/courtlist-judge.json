{
  "request": {
    "method": "GET",
    "urlPathPattern": "/listing-service/query/api/rest/listing/courtlistpayload",
    "queryParameters": {
      "listId": {"equalTo": "JUDGE"}
    },
    "headers": {
      "Accept": {"equalTo": "application/vnd.listing.search.court.list.payload+json"},
      "CJSCPPUID": {"matches": ".+"}
    }
  },
  "response": {
    "status": 200,
    "headers": {"Content-Type": "application/vnd.listing.search.court.list.payload+json"},
    "jsonBody": {
      "listType": "judge",
      "templateName": "JudgeList",
      "courtCentreName": "Test Court",
      "hearingDates": []
    }
  },
  "priority": 2
}
