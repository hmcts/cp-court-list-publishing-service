{
  "request": {
    "method": "GET",
    "urlPathPattern": "/progression-service/query/api/rest/progression/courtlistdata",
    "queryParameters": {
      "listId": {"equalTo": "USHERS_CROWN"}
    },
    "headers": {
      "Accept": {"equalTo": "application/vnd.progression.search.court.list.data+json"},
      "CJSCPPUID": {"matches": ".+"}
    }
  },
  "response": {
    "status": 200,
    "headers": {"Content-Type": "application/vnd.progression.search.court.list.data+json"},
    "jsonBody": {
      "listType": "ushers_crown",
      "templateName": "UshersCrownList",
      "courtCentreName": "Test Court",
      "hearingDates": []
    }
  },
  "priority": 2
}
