{
  "request": {
    "method": "GET",
    "urlPathPattern": "/courtlist.*",
    "queryParameters": {
      "listId": {
        "equalTo": "USHERS_CROWN"
      }
    },
    "headers": {
      "Accept": {
        "equalTo": "application/vnd.courtlist.search.court.list+json"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "court-list-payload-ushers-crown.json"
  },
  "priority": 2
}
